# === STEP 0: Install required packages ===
if (!require("httr")) install.packages("httr")
if (!require("jsonlite")) install.packages("jsonlite")
if (!require("lubridate")) install.packages("lubridate")
if (!require("dplyr")) install.packages("dplyr")
if (!require("readr")) install.packages("readr")

library(httr)
library(jsonlite)
library(lubridate)
library(dplyr)
library(readr)

# === STEP 1: Config ===
api_key <- "YOUR_API_KEY"  # <-- Replace with your Weatherstack key
location <- "Cairns"
start_date <- as.Date("2022-01-01")
end_date <- Sys.Date()

# === STEP 2: Initialize empty dataframe ===
weather_data <- data.frame()

# === STEP 3: Loop over each day ===
dates <- seq.Date(start_date, end_date, by = "day")

cat("📡 Fetching hourly historical weather for Cairns from", start_date, "to", end_date, "\n")

for (date in dates) {
  cat("→", as.character(date), "\n")
  
  url <- "http://api.weatherstack.com/historical"
  response <- GET(url, query = list(
    access_key = api_key,
    query = location,
    historical_date = as.character(date),
    hourly = "1",
    units = "m"
  ))
  
  content_raw <- content(response, as = "text", encoding = "UTF-8")
  data_parsed <- fromJSON(content_raw, flatten = TRUE)
  
  if (!is.null(data_parsed$historical[[as.character(date)]]$hourly)) {
    hourly_data <- data_parsed$historical[[as.character(date)]]$hourly
    loc <- data_parsed$location
    
    # Process each hour
    for (i in 1:nrow(hourly_data)) {
      hour_entry <- hourly_data[i, ]
      record <- data.frame(
        datetime = ymd_h(paste(date, sprintf("%02d", as.numeric(hour_entry$time) %/% 100))),
        location_name = loc$name,
        country = loc$country,
        region = loc$region,
        localtime = loc$localtime,
        temperature = hour_entry$temperature,
        feelslike = hour_entry$feelslike,
        humidity = hour_entry$humidity,
        wind_speed = hour_entry$wind_speed,
        wind_degree = hour_entry$wind_degree,
        wind_dir = hour_entry$wind_dir,
        pressure = hour_entry$pressure,
        precip = hour_entry$precip,
        cloudcover = hour_entry$cloudcover,
        visibility = hour_entry$visibility,
        heatindex = hour_entry$heatindex,
        dewpoint = hour_entry$dewpoint,
        windchill = hour_entry$windchill,
        windgust = hour_entry$windgust,
        chanceofrain = hour_entry$chanceofrain,
        chanceofremdry = hour_entry$chanceofremdry,
        chanceofwindy = hour_entry$chanceofwindy,
        chanceofovercast = hour_entry$chanceofovercast,
        chanceofsunshine = hour_entry$chanceofsunshine,
        chanceoffrost = hour_entry$chanceoffrost,
        chanceofhightemp = hour_entry$chanceofhightemp,
        chanceoffog = hour_entry$chanceoffog,
        chanceofsnow = hour_entry$chanceofsnow,
        chanceofthunder = hour_entry$chanceofthunder,
        uv_index = hour_entry$uv_index,
        weather_desc = paste(hour_entry$weather_descriptions, collapse = ", "),
        weather_icon = paste(hour_entry$weather_icons, collapse = ", ")
      )
      weather_data <- bind_rows(weather_data, record)
    }
  } else {
    warning(paste("⚠️ No data for", date, "|", data_parsed$error$info))
  }
  
  Sys.sleep(1)  # avoid API rate limits
}

# === STEP 4: Save to CSV with dynamic filename ===
filename <- paste0(
  tolower(gsub(" ", "_", location)),
  "_hourly_weather_",
  format(start_date, "%Y%m%d"), "_to_",
  format(end_date, "%Y%m%d"),
  "_all_fields.csv"
)

write_csv(weather_data, filename)
cat("✅ Full hourly historical weather saved to:", filename, "\n")

